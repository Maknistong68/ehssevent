# ─────────────────────────────────────────────────────────────────────────────
# Event Report — environment template
#
# Copy this file to `.env.local` and fill in values. The app validates these at
# boot via `src/lib/env.ts` and FAILS FAST on a missing/malformed required key.
#
# Required to boot:  the Supabase keys and NEXT_PUBLIC_APP_ORIGIN (marked below).
# Everything else is an optional integration whose shape is still validated.
#
# KSA / PDPL note: this app stores sensitive workplace injury/health data and is
# intended for In-Kingdom (Saudi Arabia) hosting. Point every backend service
# (Supabase, storage, email, monitoring) at a KSA-resident provider.
#
# NEVER commit real secrets — `.env*.local` and `.env*.production` are gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (data + auth) — REQUIRED ────────────────────────────────────────
# Public project URL + anon key are safe for the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key is SERVER-ONLY. Never expose it to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── App origin (absolute URLs, CSP connect-src, CSRF posture) — REQUIRED ──────
# e.g. https://app.example.com
NEXT_PUBLIC_APP_ORIGIN=

# ── Image optimizer allowlist — optional ─────────────────────────────────────
# Comma-separated hostnames the Next image optimizer may fetch from
# (e.g. your-project.supabase.co,cdn.example.com). Empty = no remote images.
# Photos are served via the authenticated /api/photos proxy (unoptimized), so
# this is only needed if you serve other remote images.
NEXT_PUBLIC_IMAGE_DOMAINS=

# ── Transactional email provider — optional ──────────────────────────────────
# Bind a KSA-resident provider to the sendEmail() seam (src/lib/email).
# Unset = DPO/DSR notifications are skipped (logged), not sent.
EMAIL_API_KEY=
EMAIL_FROM=

# ── Error monitoring / observability — optional ──────────────────────────────
# KSA-resident collector endpoint; reportError() forwards errors + error.digest.
NEXT_PUBLIC_MONITORING_DSN=

# ── Scheduled-job auth (retention/destruction cron) — server-only, optional ──
# Shared secret the KSA-resident scheduler sends as a Bearer token (or
# x-cron-secret header) to POST /api/cron/retention. Unset = the route 404s.
CRON_SECRET=

# ── PDPL Data Protection Officer contact (shown in UI) — optional ────────────
NEXT_PUBLIC_DPO_EMAIL=
NEXT_PUBLIC_DPO_PHONE=
NEXT_PUBLIC_DPO_ADDRESS=

# ── Operating legal entity (shown in Terms / Privacy copy) — optional ────────
NEXT_PUBLIC_LEGAL_ENTITY_NAME=
NEXT_PUBLIC_LEGAL_EMAIL=
